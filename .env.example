# ---------------------------------------------------------------------------
# WRC pipeline configuration.
# Copy to `.env` and adjust. All values are also overridable as real env vars.
# Every tunable lives here — there are no hardcoded connection strings,
# paths, partition sizes, or scraping parameters in the code.
# ---------------------------------------------------------------------------

# --- MongoDB (NoSQL metadata store) ---
WRC_MONGO_URI=mongodb://localhost:27017
WRC_MONGO_DB=wrc
WRC_LANDING_COLLECTION=landing_decisions
WRC_CURATED_COLLECTION=curated_decisions

# --- MinIO / S3 (object storage) ---
WRC_S3_ENDPOINT_URL=http://localhost:9000
WRC_S3_ACCESS_KEY=minioadmin
WRC_S3_SECRET_KEY=minioadmin
WRC_S3_REGION=us-east-1
WRC_LANDING_BUCKET=landing
WRC_CURATED_BUCKET=curated

# --- Target site (override only if the site moves) ---
WRC_BASE_URL=https://www.workplacerelations.ie
WRC_SEARCH_PATH=/en/search/

# --- Scraping window & partitioning ---
# Defaults used when the CLI is invoked without explicit dates.
WRC_START_DATE=2024-01-01
WRC_END_DATE=2024-04-01
# Partition granularity: monthly | weekly | yearly
WRC_PARTITION_SIZE=monthly
# Comma-separated body keys to scrape. Omit / leave blank to scrape all.
# Keys: workplace_relations_commission, labour_court, equality_tribunal, employment_appeals_tribunal
WRC_BODIES=

# --- Politeness / anti-block tuning (Scrapy) ---
WRC_USER_AGENT=wrc-research-bot/0.1 (+contact: you@example.com)
WRC_CONCURRENT_REQUESTS=8
WRC_DOWNLOAD_DELAY=0.25
WRC_AUTOTHROTTLE_ENABLED=true
WRC_DOWNLOAD_TIMEOUT=60
WRC_RETRY_TIMES=3
WRC_ROBOTSTXT_OBEY=true
WRC_LOG_LEVEL=INFO

# --- Idempotency ---
# When true, re-fetch already-known documents to detect content changes via
# file hash. When false, skip known identifiers entirely (zero re-downloads).
WRC_RECHECK_EXISTING=true
